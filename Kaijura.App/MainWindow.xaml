<Window x:Class="Kaijura.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Kaijura"
        Icon="Assets/Logo.png"
        Width="1480"
        Height="920"
        MinWidth="1100"
        MinHeight="720"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#0e0e10"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitlebarNavigationButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#a7a7ad" />
            <Setter Property="FontFamily" Value="Aptos, Bahnschrift" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="ButtonBackground"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBackground" Property="Background" Value="#1a1a1e" />
                                <Setter TargetName="ButtonBackground" Property="BorderBrush" Value="#28282e" />
                                <Setter Property="Foreground" Value="#f0f0f0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBackground" Property="Background" Value="#232329" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonBackground" Property="Background" Value="#232329" />
                                <Setter TargetName="ButtonBackground" Property="BorderBrush" Value="#313137" />
                                <Setter Property="Foreground" Value="#f0f0f0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChromeButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#a7a7ad" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBackground"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBackground" Property="Background" Value="#232329" />
                                <Setter Property="Foreground" Value="#f0f0f0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBackground" Property="Background" Value="#313137" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitlebarStatusButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#313137" />
            <Setter Property="Background" Value="#232329" />
            <Setter Property="Foreground" Value="#f0f0f0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBackground"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBackground" Property="BorderBrush" Value="#43434a" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBackground" Property="Background" Value="#313137" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseChromeButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource ChromeButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBackground"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBackground" Property="Background" Value="#c42b1c" />
                                <Setter Property="Foreground" Value="#ffffff" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBackground" Property="Background" Value="#8f1f15" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#0e0e10">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#141416">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.ColumnSpan="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsHitTestVisible="False"
                        Orientation="Horizontal">
                <Image Width="22"
                       Height="22"
                       Margin="0,0,7,0"
                       Source="Assets/Logo.png" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="#f0f0f0"
                           FontFamily="Aptos, Bahnschrift"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Text="Kaijura" />
            </StackPanel>

            <StackPanel Grid.Column="0"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <ToggleButton x:Name="BoardNavigationButton"
                              Style="{StaticResource TitlebarNavigationButtonStyle}"
                              Content="Tablero"
                              Tag="board"
                              Click="OnNavigationButtonClick"
                              AutomationProperties.Name="Tablero" />
                <ToggleButton x:Name="ArchiveNavigationButton"
                              Style="{StaticResource TitlebarNavigationButtonStyle}"
                              Content="Archivo"
                              Tag="archive"
                              Click="OnNavigationButtonClick"
                              AutomationProperties.Name="Archivo" />
                <ToggleButton x:Name="MissingNavigationButton"
                              Style="{StaticResource TitlebarNavigationButtonStyle}"
                              Content="Ocultos"
                              Tag="missing"
                              Click="OnNavigationButtonClick"
                              AutomationProperties.Name="Ocultos" />
                <ToggleButton x:Name="UnmappedNavigationButton"
                              Style="{StaticResource TitlebarNavigationButtonStyle}"
                              Content="Sin mapear"
                              Tag="unmapped"
                              Click="OnNavigationButtonClick"
                              AutomationProperties.Name="Sin mapear" />
                <ToggleButton x:Name="SettingsNavigationButton"
                              Style="{StaticResource TitlebarNavigationButtonStyle}"
                              Content="Ajustes"
                              Tag="settings"
                              Click="OnNavigationButtonClick"
                              AutomationProperties.Name="Ajustes" />
            </StackPanel>

            <StackPanel x:Name="TitlebarStatusPanel"
                        Grid.Column="2"
                        Margin="0,0,18,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Ellipse x:Name="TitlebarConnectionStatusDot"
                         Width="9"
                         Height="9"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"
                         Fill="#73737b" />
                <TextBlock x:Name="TitlebarStatusTextBlock"
                           Margin="0,0,10,0"
                           VerticalAlignment="Center"
                           Foreground="#a7a7ad"
                           FontFamily="Aptos, Bahnschrift"
                           FontSize="13" />
                <Button x:Name="TitlebarRefreshButton"
                        Style="{StaticResource TitlebarStatusButtonStyle}"
                        Content="&#xE72C;"
                        Click="OnTitlebarRefreshButtonClick"
                        AutomationProperties.Name="Refrescar"
                        ToolTip="Refrescar" />
            </StackPanel>

            <StackPanel Grid.Column="3"
                        Orientation="Horizontal"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Style="{StaticResource ChromeButtonStyle}"
                        Content="&#xE921;"
                        Click="OnMinimizeButtonClick"
                        AutomationProperties.Name="Minimizar"
                        ToolTip="Minimizar" />
                <Button x:Name="MaximizeButton"
                        Style="{StaticResource ChromeButtonStyle}"
                        Content="&#xE922;"
                        Click="OnMaximizeButtonClick"
                        AutomationProperties.Name="Maximizar"
                        ToolTip="Maximizar" />
                <Button Style="{StaticResource CloseChromeButtonStyle}"
                        Content="&#xE8BB;"
                        Click="OnCloseButtonClick"
                        AutomationProperties.Name="Cerrar"
                        ToolTip="Cerrar" />
            </StackPanel>
        </Grid>

        <wv2:WebView2 x:Name="Browser" Grid.Row="1">
            <wv2:WebView2.Style>
                <Style TargetType="{x:Type wv2:WebView2}">
                    <Setter Property="Margin" Value="6,0,6,6" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                     Value="Maximized">
                            <Setter Property="Margin" Value="0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </wv2:WebView2.Style>
        </wv2:WebView2>
    </Grid>
</Window>
